# Groq API Key (get from console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Polling interval in minutes
POLL_INTERVAL_MINUTES=1

# Email subject to filter for
EMAIL_SUBJECT_FILTER=BiziShip new Quotes request

# Priority1 API settings
PRIORITY1_API_KEY=your-priority1-api-key-here
PRIORITY1_API_URL=https://dev-api.priority1.com

# REST API settings
API_KEY=your-secret-api-key-here
API_HOST=0.0.0.0
API_PORT=8000
MAX_UPLOAD_MB=20
